generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  PLAYER
}

enum TournamentStatus {
  REGISTRATION
  ACTIVE
  COMPLETED
}

enum HandicapSystem {
  NONE
  WHS
  STABLEFORD
  CALLAWAY
  PEORIA
}

enum TeeMode {
  UNIFORM
  CUSTOM
}

enum PowerupType {
  BOOST
  ATTACK
}

enum DraftFormat {
  LINEAR
  SNAKE
}

enum DraftTiming {
  PRE_TOURNAMENT
  PRE_ROUND
}

enum DraftStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum NotificationType {
  ATTACK_RECEIVED
  DRAFT_YOUR_TURN
  ROUND_STARTED
  TOURNAMENT_INVITE
  POWERUP_USED
  DRAFT_STARTED
  DRAFT_COMPLETED
  TEE_TIME_ASSIGNED
}

enum PlayerPowerupStatus {
  AVAILABLE
  ACTIVE
  USED
}

enum DistributionMode {
  DRAFT
  RANDOM
}

enum TournamentType {
  PUBLIC
  OPEN
  INVITE
}

enum TournamentFormat {
  STROKE_PLAY
  STROKE_PLAY_NET
  STABLEFORD
  MODIFIED_STABLEFORD
  BEST_BALL
  BEST_BALL_2
  BEST_BALL_4
  SCRAMBLE
  SHAMBLE
  MATCH_PLAY
  RYDER_CUP
  SKINS
  SKINS_GROSS
  SKINS_NET
  QUOTA
  CALLAWAY
  PEORIA
  CHAPMAN
  PINEHURST
  LOW_GROSS_LOW_NET
}

enum PricingTier {
  FREE
  PRO
  CLUB
  LEAGUE
}

enum PurchaseType {
  EVENT
  CLUB
  LEAGUE
}

enum PurchaseStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
}

enum SeasonScoringMethod {
  POINTS
  STROKE_AVG
  BEST_OF_N
  STABLEFORD_CUMULATIVE
}

enum RosterStatus {
  ACTIVE
  INACTIVE
}

enum RSVPStatus {
  GOING
  NOT_GOING
  MAYBE
}

// ─── Auth (NextAuth adapter) ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(PLAYER)
  createdAt     DateTime  @default(now())

  phone            String?
  smsNotifications Boolean @default(false)

  accounts               Account[]
  sessions               Session[]
  profile                PlayerProfile?
  tournamentPlayers      TournamentPlayer[]
  invitations            Invitation[]
  standaloneRounds       StandaloneRound[]
  messages               TournamentMessage[]
  photos                 TournamentPhoto[]
  chatBans               ChatBan[]
  purchases              Purchase[]
  stripeCustomerId       String?                      @unique
  rosterMemberships      LeagueRosterMember[]
  seasonRSVPs            SeasonRSVP[]
  sentAnnouncements      LeagueAnnouncement[]         @relation("LeagueAnnouncementsSentBy")
  announcementDeliveries LeagueAnnouncementDelivery[]
  ownedAdminSeats        AccountAdmin[]               @relation("AccountAdminOwner")
  delegatedAdminFor      AccountAdmin[]               @relation("AccountAdminUser")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Player Profile ───────────────────────────────────────────────────────────

model PlayerProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  displayName String?
  avatar      String?
  handicap    Float   @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Tournament ───────────────────────────────────────────────────────────────

model Tournament {
  id                   String           @id @default(cuid())
  slug                 String           @unique
  joinCode             String?          @unique
  name                 String
  description          String?
  logo                 String?
  headerImage          String?
  primaryColor         String           @default("#006747")
  accentColor          String           @default("#C9A84C")
  status               TournamentStatus @default(REGISTRATION)
  tournamentType       TournamentType   @default(OPEN)
  isOpenRegistration   Boolean          @default(false)
  registrationClosed   Boolean          @default(false)
  handicapSystem       HandicapSystem   @default(WHS)
  tournamentFormat     TournamentFormat @default(STROKE_PLAY)
  formatConfig         Json?
  teamsEnabled         Boolean          @default(false)
  teamSize             Int?
  powerupsEnabled      Boolean          @default(false)
  powerupsPerPlayer    Int              @default(3)
  maxAttacksPerPlayer  Int              @default(1)
  distributionMode     DistributionMode @default(DRAFT)
  startDate            DateTime?
  endDate              DateTime?
  registrationDeadline DateTime?
  createdAt            DateTime         @default(now())

  // ── Sponsor placements (Club & Tour tiers) ──
  // For league roots (isLeague=true), this is the league sponsor that applies
  // to all child tournaments by default. For child tournaments, set these to
  // override the league-level sponsor. Resolution: tournament wins if set,
  // else fall back to root tournament's values, else show nothing.
  sponsorName    String?
  sponsorLogoUrl String?
  sponsorLink    String?

  // ── Custom subdomain (Tour tier, league roots only) ──
  // Only meaningful when isLeague=true. Resolves <subdomain>.yourmajor.app
  // to this league via middleware.
  subdomain String? @unique

  // ── Renewal chain ──
  parentTournamentId String?
  parentTournament   Tournament?  @relation("TournamentRenewal", fields: [parentTournamentId], references: [id])
  childTournaments   Tournament[] @relation("TournamentRenewal")
  championUserId     String?
  championName       String?

  // ── Season/League config (Tour tier) ──
  isLeague              Boolean              @default(false)
  leagueEndDate         DateTime?
  seasonScoringMethod   SeasonScoringMethod?
  seasonBestOf          Int?
  seasonPointsTable     Json?
  seasonDropLowest      Int?
  seasonTiebreakers     Json?
  seasonAttendanceBonus Json?
  seasonAdjustments     SeasonAdjustment[]   @relation("SeasonAdjustmentsForRoot")

  rounds              TournamentRound[]
  players             TournamentPlayer[]
  groups              TournamentGroup[]
  invitations         Invitation[]
  tournamentPowerups  TournamentPowerup[]
  draft               Draft?
  messages            TournamentMessage[]
  photos              TournamentPhoto[]
  chatBans            ChatBan[]
  purchase            Purchase?
  leagueRoster        LeagueRoster?
  seasonSchedule      SeasonScheduleEvent[]
  teams               TournamentTeam[]
  leagueAnnouncements LeagueAnnouncement[]  @relation("LeagueAnnouncementsForRoot")
}

model SeasonAdjustment {
  id               String   @id @default(cuid())
  rootTournamentId String
  userId           String
  delta            Int
  reason           String
  createdAt        DateTime @default(now())
  createdBy        String

  rootTournament Tournament @relation("SeasonAdjustmentsForRoot", fields: [rootTournamentId], references: [id], onDelete: Cascade)

  @@index([rootTournamentId])
}

model TournamentTeam {
  id           String   @id @default(cuid())
  tournamentId String
  name         String
  color        String?
  createdAt    DateTime @default(now())

  tournament Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  members    TournamentTeamMember[]

  @@index([tournamentId])
}

model TournamentTeamMember {
  id                 String @id @default(cuid())
  teamId             String
  tournamentPlayerId String @unique

  team             TournamentTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournamentPlayer TournamentPlayer @relation(fields: [tournamentPlayerId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TournamentRound {
  id           String    @id @default(cuid())
  tournamentId String
  roundNumber  Int
  date         DateTime?
  courseId     String
  teeMode      TeeMode   @default(UNIFORM)

  tournament      Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  course          Course           @relation(fields: [courseId], references: [id])
  scores          Score[]
  roundPlayerTees RoundPlayerTee[]
  roundHoleTees   RoundHoleTee[]
  playerPowerups  PlayerPowerup[]

  @@unique([tournamentId, roundNumber])
}

// ─── Course ───────────────────────────────────────────────────────────────────

model Course {
  id         String  @id @default(cuid())
  externalId String? @unique
  name       String
  location   String?
  latitude   Float?
  longitude  Float?
  par        Int     @default(72)
  isCustom   Boolean @default(false)

  holes            Hole[]
  teeOptions       TeeOption[]
  rounds           TournamentRound[]
  standaloneRounds StandaloneRound[]
}

model Hole {
  id       String @id @default(cuid())
  courseId String
  number   Int
  par      Int
  handicap Int?

  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  yardages         HoleYardage[]
  scores           Score[]
  standaloneScores StandaloneScore[]

  @@unique([courseId, number])
}

model TeeOption {
  id           String  @id @default(cuid())
  courseId     String
  name         String
  color        String?
  courseRating Float?
  slopeRating  Int?

  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  yardages         HoleYardage[]
  standaloneRounds StandaloneRound[]
  roundPlayerTees  RoundPlayerTee[]
  roundHoleTees    RoundHoleTee[]
}

model HoleYardage {
  id          String @id @default(cuid())
  holeId      String
  teeOptionId String
  yards       Int

  hole      Hole      @relation(fields: [holeId], references: [id], onDelete: Cascade)
  teeOption TeeOption @relation(fields: [teeOptionId], references: [id], onDelete: Cascade)

  @@unique([holeId, teeOptionId])
}

// ─── Round Tee Assignments ─────────────────────────────────────────────────────

model RoundPlayerTee {
  id                 String @id @default(cuid())
  roundId            String
  tournamentPlayerId String
  teeOptionId        String

  round            TournamentRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  tournamentPlayer TournamentPlayer @relation(fields: [tournamentPlayerId], references: [id], onDelete: Cascade)
  teeOption        TeeOption        @relation(fields: [teeOptionId], references: [id])

  @@unique([roundId, tournamentPlayerId])
}

model RoundHoleTee {
  id          String @id @default(cuid())
  roundId     String
  holeNumber  Int
  teeOptionId String

  round     TournamentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  teeOption TeeOption       @relation(fields: [teeOptionId], references: [id])

  @@unique([roundId, holeNumber])
}

// ─── Tournament Players ───────────────────────────────────────────────────────

model TournamentPlayer {
  id            String   @id @default(cuid())
  tournamentId  String
  userId        String
  tee           String?
  handicap      Float    @default(0)
  isAdmin       Boolean  @default(false)
  isParticipant Boolean  @default(true)
  createdAt     DateTime @default(now())

  tournament      Tournament             @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  scores          Score[]
  playerPowerups  PlayerPowerup[]
  draftPicks      DraftPick[]
  notifications   Notification[]
  roundPlayerTees RoundPlayerTee[]
  groupMembership TournamentGroupMember?
  teamMembership  TournamentTeamMember?

  @@unique([tournamentId, userId])
}

model Invitation {
  id           String    @id @default(cuid())
  tournamentId String
  email        String?
  phone        String?
  token        String    @unique @default(cuid())
  userId       String?
  acceptedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id])
}

// ─── Tournament Groups (Foursomes) ────────────────────────────────────────

model TournamentGroup {
  id                    String    @id @default(cuid())
  tournamentId          String
  name                  String
  teeTime               DateTime?
  startingHole          Int?
  lastNotifiedTeeTime   DateTime?
  lastNotifiedStartHole Int?
  createdAt             DateTime  @default(now())

  tournament Tournament              @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  members    TournamentGroupMember[]

  @@index([tournamentId])
}

model TournamentGroupMember {
  id                 String    @id @default(cuid())
  groupId            String
  tournamentPlayerId String    @unique
  position           Int
  notifiedAt         DateTime?

  group            TournamentGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tournamentPlayer TournamentPlayer @relation(fields: [tournamentPlayerId], references: [id], onDelete: Cascade)
}

// ─── Scoring ──────────────────────────────────────────────────────────────────

model Score {
  id                 String   @id @default(cuid())
  tournamentPlayerId String
  holeId             String
  roundId            String
  strokes            Int
  fairwayHit         Boolean?
  gir                Boolean?
  putts              Int?
  submittedAt        DateTime @default(now())

  tournamentPlayer TournamentPlayer @relation(fields: [tournamentPlayerId], references: [id], onDelete: Cascade)
  hole             Hole             @relation(fields: [holeId], references: [id])
  round            TournamentRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([tournamentPlayerId, holeId, roundId])
  @@index([tournamentPlayerId, roundId])
  @@index([roundId])
}

// ─── Powerup System ───────────────────────────────────────────────────────────

model Powerup {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  type        PowerupType
  description String
  effect      Json

  tournamentPowerups TournamentPowerup[]
  playerPowerups     PlayerPowerup[]
  draftPicks         DraftPick[]
}

model TournamentPowerup {
  id           String @id @default(cuid())
  tournamentId String
  powerupId    String
  quantity     Int    @default(1)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  powerup    Powerup    @relation(fields: [powerupId], references: [id])

  @@unique([tournamentId, powerupId])
}

model PlayerPowerup {
  id                 String              @id @default(cuid())
  tournamentPlayerId String
  powerupId          String
  usedAt             DateTime?
  targetPlayerId     String?
  roundId            String?
  holeNumber         Int?
  scoreModifier      Int?
  status             PlayerPowerupStatus @default(AVAILABLE)
  metadata           Json?

  tournamentPlayer TournamentPlayer @relation(fields: [tournamentPlayerId], references: [id], onDelete: Cascade)
  powerup          Powerup          @relation(fields: [powerupId], references: [id])
  round            TournamentRound? @relation(fields: [roundId], references: [id])

  @@index([tournamentPlayerId])
}

// ─── Draft ────────────────────────────────────────────────────────────────────

model Draft {
  id           String      @id @default(cuid())
  tournamentId String      @unique
  format       DraftFormat @default(SNAKE)
  timing       DraftTiming @default(PRE_TOURNAMENT)
  status       DraftStatus @default(PENDING)
  draftOrder   Json?
  currentPick  Int         @default(0)
  createdAt    DateTime    @default(now())

  tournament Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  picks      DraftPick[]
}

model DraftPick {
  id                 String @id @default(cuid())
  draftId            String
  tournamentPlayerId String
  powerupId          String
  pickNumber         Int
  roundNumber        Int?

  draft            Draft            @relation(fields: [draftId], references: [id], onDelete: Cascade)
  tournamentPlayer TournamentPlayer @relation(fields: [tournamentPlayerId], references: [id], onDelete: Cascade)
  powerup          Powerup          @relation(fields: [powerupId], references: [id])

  @@index([draftId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id                 String           @id @default(cuid())
  tournamentPlayerId String
  type               NotificationType
  payload            Json
  readAt             DateTime?
  createdAt          DateTime         @default(now())

  tournamentPlayer TournamentPlayer @relation(fields: [tournamentPlayerId], references: [id], onDelete: Cascade)

  @@index([tournamentPlayerId])
}

// ─── Tournament Chat & Photos ─────────────────────────────────────────────────

model TournamentMessage {
  id           String    @id @default(cuid())
  tournamentId String
  userId       String
  content      String
  isSystem     Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
}

model TournamentPhoto {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  url          String
  caption      String?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatBan {
  id           String    @id @default(cuid())
  tournamentId String
  userId       String
  reason       String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  createdBy    String

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
}

// ─── Standalone Rounds ────────────────────────────────────────────────────────

model StandaloneRound {
  id                  String   @id @default(cuid())
  userId              String
  courseId            String?
  selectedTeeOptionId String?
  playedAt            DateTime @default(now())
  notes               String?

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course?           @relation(fields: [courseId], references: [id])
  selectedTeeOption TeeOption?        @relation(fields: [selectedTeeOptionId], references: [id])
  scores            StandaloneScore[]
}

model StandaloneScore {
  id                String   @id @default(cuid())
  standaloneRoundId String
  holeNumber        Int
  holeId            String?
  par               Int      @default(4)
  strokes           Int
  fairwayHit        Boolean?
  gir               Boolean?
  putts             Int?
  submittedAt       DateTime @default(now())

  round StandaloneRound @relation(fields: [standaloneRoundId], references: [id], onDelete: Cascade)
  hole  Hole?           @relation(fields: [holeId], references: [id])

  @@unique([standaloneRoundId, holeNumber])
}

// ─── League Roster ────────────────────────────────────────────────────────────

model LeagueRoster {
  id               String   @id @default(cuid())
  rootTournamentId String   @unique
  autoAddNew       Boolean  @default(true)
  createdAt        DateTime @default(now())

  rootTournament Tournament           @relation(fields: [rootTournamentId], references: [id], onDelete: Cascade)
  members        LeagueRosterMember[]
}

model LeagueRosterMember {
  id       String       @id @default(cuid())
  rosterId String
  userId   String
  status   RosterStatus @default(ACTIVE)
  joinedAt DateTime     @default(now())

  roster LeagueRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rosterId, userId])
}

// ─── Season Schedule & RSVP ──────────────────────────────────────────────────

model SeasonScheduleEvent {
  id           String   @id @default(cuid())
  tournamentId String
  title        String
  date         DateTime
  courseId     String?
  notes        String?
  createdAt    DateTime @default(now())

  tournament Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rsvps      SeasonRSVP[]

  @@index([tournamentId])
}

model SeasonRSVP {
  id      String     @id @default(cuid())
  eventId String
  userId  String
  status  RSVPStatus @default(GOING)

  event SeasonScheduleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

// ─── Account-Level Admin Seats (Club: 2 seats, Tour: 5 seats) ─────────────────
// Co-admins inherit admin rights on every tournament/league owned by `owner`.
// The owner counts as 1 of the tier's seat budget; AccountAdmin rows are the
// additional invited admins (so 2 seats = owner + 1 row, 5 seats = owner + 4 rows).

model AccountAdmin {
  id           String   @id @default(cuid())
  ownerUserId  String
  adminUserId  String
  invitedEmail String?
  acceptedAt   DateTime?
  createdAt    DateTime @default(now())

  owner User @relation("AccountAdminOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  admin User @relation("AccountAdminUser", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, adminUserId])
  @@index([ownerUserId])
  @@index([adminUserId])
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model Purchase {
  id              String         @id @default(cuid())
  userId          String
  tournamentId    String?        @unique
  type            PurchaseType
  status          PurchaseStatus @default(ACTIVE)
  stripeSessionId String?        @unique
  stripeSubId     String?        @unique
  amount          Int // cents
  expiresAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ─── League Communications ────────────────────────────────────────────────────

model LeagueAnnouncement {
  id               String    @id @default(cuid())
  rootTournamentId String
  subject          String
  body             String
  channels         String[] // ["EMAIL"], ["SMS"], or both
  audienceFilter   Json // { type: 'ALL_ACTIVE' | 'ALL_ROSTER' | 'CUSTOM', userIds?: string[] }
  sentAt           DateTime?
  sentByUserId     String
  createdAt        DateTime  @default(now())

  rootTournament Tournament                   @relation("LeagueAnnouncementsForRoot", fields: [rootTournamentId], references: [id], onDelete: Cascade)
  sentBy         User                         @relation("LeagueAnnouncementsSentBy", fields: [sentByUserId], references: [id])
  deliveries     LeagueAnnouncementDelivery[]

  @@index([rootTournamentId])
}

model LeagueAnnouncementDelivery {
  id             String    @id @default(cuid())
  announcementId String
  userId         String
  channel        String // "EMAIL" | "SMS"
  status         String // "PENDING" | "SENT" | "FAILED" | "SKIPPED"
  failureReason  String?
  deliveredAt    DateTime?

  announcement LeagueAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([announcementId])
  @@index([userId])
}
